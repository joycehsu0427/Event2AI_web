@baseUrl = http://localhost:8080

### 登入
# @name login
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "demo_user",
  "password": "demoPass123"
}

### 從登入回應擷取 token
@accessToken = eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiIzMTAwMDAwMC0wMDAwLTAwMDAtMDAwMC0wMDAwMDAwMDAwMDAiLCJpYXQiOjE3NzI1Mzk5MzQsImV4cCI6MTc3MjU0MzUzNH0.0JOEUg4alsF0IuQKxqa5IOPmWC1SSjVlgQdEY95Wous
@userId = 00000000-0000-0000-0000-000000000000

### ===== User CRUD =====

### 取得目前登入使用者（需要 JWT）
GET {{baseUrl}}/api/users/me
Authorization: Bearer {{accessToken}}

### 取得所有使用者（需要 JWT）
GET {{baseUrl}}/api/users
Authorization: Bearer {{accessToken}}

### 依 userId 取得使用者（需要 JWT）
GET {{baseUrl}}/api/users/{{userId}}
Authorization: Bearer {{accessToken}}

### 依 username 取得使用者（需要 JWT）
GET {{baseUrl}}/api/users/username/demo_user
Authorization: Bearer {{accessToken}}

### 更新使用者（需要 JWT，所有欄位皆可選填）
PUT {{baseUrl}}/api/users/{{userId}}
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "username": "demo_user_updated",
  "email": "demo_updated@example.com",
  "password": "newPassword123"
}

### 刪除使用者（需要 JWT）
DELETE {{baseUrl}}/api/users/{{userId}}
Authorization: Bearer {{accessToken}}
