@baseUrl = http://localhost:8080

### 登入
# @name login
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "demo_user",
  "password": "demoPass123"
}

### 從登入回應擷取 token
@accessToken = eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiIzMTAwMDAwMC0wMDAwLTAwMDAtMDAwMC0wMDAwMDAwMDAwMDAiLCJpYXQiOjE3NzI1Mzk5MzQsImV4cCI6MTc3MjU0MzUzNH0.0JOEUg4alsF0IuQKxqa5IOPmWC1SSjVlgQdEY95Wous
@boardId = a4221021-1cdc-4135-959a-71550254b226
@domainEntityId = 00000000-0000-0000-0000-000000000000

### ===== DomainEntity CRUD =====

### 取得所有 DomainEntities（需要 JWT）
GET {{baseUrl}}/api/domain-entities
Authorization: Bearer {{accessToken}}

### 依 domainEntityId 取得 DomainEntity（需要 JWT）
GET {{baseUrl}}/api/domain-entities?domainEntityId={{domainEntityId}}
Authorization: Bearer {{accessToken}}

### 依 boardId 取得 DomainEntities（需要 JWT）
GET {{baseUrl}}/api/domain-entities?boardId={{boardId}}
Authorization: Bearer {{accessToken}}

### 建立 DomainEntity：含多個 attributes（需要 JWT）
# @name createDomainEntity
POST {{baseUrl}}/api/domain-entities
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "boardId": "{{boardId}}",
  "posX": 100.0,
  "posY": 200.0,
  "width": 240.0,
  "height": 160.0,
  "name": "User",
  "description": "代表系統中的使用者實體",
  "attributes": [
    {
      "name": "id",
      "dataType": "UUID",
      "constraint": "PRIMARY KEY",
      "displayOrder": 0
    },
    {
      "name": "username",
      "dataType": "VARCHAR(100)",
      "constraint": "NOT NULL UNIQUE",
      "displayOrder": 1
    },
    {
      "name": "email",
      "dataType": "VARCHAR(255)",
      "constraint": "NOT NULL UNIQUE",
      "displayOrder": 2
    },
    {
      "name": "createdAt",
      "dataType": "TIMESTAMP",
      "constraint": "NOT NULL",
      "displayOrder": 3
    }
  ]
}

### 建立 DomainEntity：無 attributes（需要 JWT）
POST {{baseUrl}}/api/domain-entities
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "boardId": "{{boardId}}",
  "posX": 400.0,
  "posY": 200.0,
  "width": 200.0,
  "height": 120.0,
  "name": "Order",
  "description": "訂單實體",
  "attributes": []
}

### 建立 DomainEntity：無 description（需要 JWT）
POST {{baseUrl}}/api/domain-entities
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "boardId": "{{boardId}}",
  "posX": 700.0,
  "posY": 200.0,
  "width": 200.0,
  "height": 120.0,
  "name": "Product",
  "attributes": [
    {
      "name": "id",
      "dataType": "UUID",
      "constraint": "PRIMARY KEY",
      "displayOrder": 0
    },
    {
      "name": "price",
      "dataType": "DECIMAL(10,2)",
      "constraint": "NOT NULL",
      "displayOrder": 1
    }
  ]
}

### 更新 DomainEntity：修改名稱與描述（需要 JWT，所有欄位皆可選填）
PUT {{baseUrl}}/api/domain-entities/{{domainEntityId}}
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "name": "AppUser",
  "description": "更新後的使用者實體描述"
}

### 更新 DomainEntity：修改位置與尺寸（需要 JWT）
PUT {{baseUrl}}/api/domain-entities/{{domainEntityId}}
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "posX": 150.0,
  "posY": 250.0,
  "width": 280.0,
  "height": 200.0
}

### 更新 DomainEntity：替換 attributes（需要 JWT）
PUT {{baseUrl}}/api/domain-entities/{{domainEntityId}}
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "attributes": [
    {
      "name": "id",
      "dataType": "UUID",
      "constraint": "PRIMARY KEY",
      "displayOrder": 0
    },
    {
      "name": "username",
      "dataType": "VARCHAR(100)",
      "constraint": "NOT NULL UNIQUE",
      "displayOrder": 1
    },
    {
      "name": "passwordHash",
      "dataType": "VARCHAR(255)",
      "constraint": "NOT NULL",
      "displayOrder": 2
    },
    {
      "name": "role",
      "dataType": "VARCHAR(50)",
      "constraint": "NOT NULL DEFAULT 'USER'",
      "displayOrder": 3
    }
  ]
}

### 刪除 DomainEntity（需要 JWT）
DELETE {{baseUrl}}/api/domain-entities/{{domainEntityId}}
Authorization: Bearer {{accessToken}}
