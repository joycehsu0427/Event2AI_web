@baseUrl = http://localhost:8080

### 註冊
# @name register
POST {{baseUrl}}/api/auth/register
Content-Type: application/json

{
  "username": "demo_user",
  "email": "demo_user@example.com",
  "password": "demoPass123"
}

### 登入
# @name login
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "demo_user",
  "password": "demoPass123"
}

### 從登入回應擷取 token
@accessToken = eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiIzMTAwMDAwMC0wMDAwLTAwMDAtMDAwMC0wMDAwMDAwMDAwMDAiLCJpYXQiOjE3NzI1Mzk5MzQsImV4cCI6MTc3MjU0MzUzNH0.0JOEUg4alsF0IuQKxqa5IOPmWC1SSjVlgQdEY95Wous
@boardId = a4221021-1cdc-4135-959a-71550254b226
@stickyNoteId = b6185e51-6710-40c2-8a8d-bc63e2651ac7

### 取得所有 StickyNotes（需要 JWT）
GET {{baseUrl}}/api/sticky-notes
Authorization: Bearer {{accessToken}}

### 依 id 取得 StickyNote（需要 JWT）
GET {{baseUrl}}/api/sticky-notes?id={{stickyNoteId}}
Authorization: Bearer {{accessToken}}

### 依 boardId 取得 StickyNotes（需要 JWT）
GET {{baseUrl}}/api/sticky-notes?boardId={{boardId}}
Authorization: Bearer {{accessToken}}

### 依 boardId + color 取得 StickyNotes（需要 JWT）
GET {{baseUrl}}/api/sticky-notes?boardId={{boardId}}&color=green
Authorization: Bearer {{accessToken}}

### 依 color 取得 StickyNotes（需要 JWT）
GET {{baseUrl}}/api/sticky-notes?color=green
Authorization: Bearer {{accessToken}}

### 建立 StickyNote（需要 JWT）
# @name createStickyNote
POST {{baseUrl}}/api/sticky-notes
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "boardId": "{{boardId}}",
  "posX": 0.0,
  "posY": 0.0,
  "geoX": 50.0,
  "geoY": 50.0,
  "description": "This is a new description for test.",
  "color": "green",
  "tag": "not done"
}

### 更新 StickyNote（需要 JWT，所有欄位皆可選填）
PUT {{baseUrl}}/api/sticky-notes/{{stickyNoteId}}
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "description": "Updated description.",
  "color": "yellow",
  "tag": "in progress"
}

### 刪除 StickyNote（需要 JWT）
DELETE {{baseUrl}}/api/sticky-notes/{{stickyNoteId}}
Authorization: Bearer {{accessToken}}
