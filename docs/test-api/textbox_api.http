@baseUrl = http://localhost:8080

### 註冊
# @name register
POST {{baseUrl}}/api/auth/register
Content-Type: application/json

{
  "username": "demo_user",
  "email": "demo_user@example.com",
  "password": "demoPass123"
}

### 登入
# @name login
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "demo_user",
  "password": "demoPass123"
}

### 從登入回應擷取 token
@accessToken = eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiIzMTAwMDAwMC0wMDAwLTAwMDAtMDAwMC0wMDAwMDAwMDAwMDAiLCJpYXQiOjE3NzI1Mzk5MzQsImV4cCI6MTc3MjU0MzUzNH0.0JOEUg4alsF0IuQKxqa5IOPmWC1SSjVlgQdEY95Wous
@boardId = a4221021-1cdc-4135-959a-71550254b226
@textBoxId = 00000000-0000-0000-0000-000000000000

### 取得所有 TextBoxes（需要 JWT）
GET {{baseUrl}}/api/text_boxes
Authorization: Bearer {{accessToken}}

### 依 textBoxId 取得 TextBox（需要 JWT）
GET {{baseUrl}}/api/text_boxes?textBoxId={{textBoxId}}
Authorization: Bearer {{accessToken}}

### 依 boardId 取得 TextBoxes（需要 JWT）
GET {{baseUrl}}/api/text_boxes?boardId={{boardId}}
Authorization: Bearer {{accessToken}}

### 建立 TextBox（需要 JWT）
# @name createTextBox
POST {{baseUrl}}/api/text_boxes
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "boardId": "{{boardId}}",
  "posX": 100.0,
  "posY": 200.0,
  "geoX": 300.0,
  "geoY": 150.0,
  "description": "This is a text box for testing.",
  "tag": "important",
  "fontColor": "#000000",
  "fontSize": "14px"
}

### 更新 TextBox（需要 JWT，所有欄位皆可選填）
PUT {{baseUrl}}/api/text_boxes/{{textBoxId}}
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "posX": 120.0,
  "posY": 220.0,
  "description": "Updated description.",
  "tag": "done",
  "fontColor": "#ff0000",
  "fontSize": "16px"
}

### 刪除 TextBox（需要 JWT）
DELETE {{baseUrl}}/api/text_boxes/{{textBoxId}}
Authorization: Bearer {{accessToken}}
