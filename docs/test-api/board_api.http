@baseUrl = http://localhost:8080

### 註冊
# @name register
POST {{baseUrl}}/api/auth/register
Content-Type: application/json

{
  "username": "demo_user",
  "email": "demo_user@example.com",
  "password": "demoPass123"
}

### 登入
# @name login
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "demo_user",
  "password": "demoPass123"
}

### 從登入回應擷取 token
@accessToken = eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiIzMTAwMDAwMC0wMDAwLTAwMDAtMDAwMC0wMDAwMDAwMDAwMDAiLCJpYXQiOjE3NzI1MzU2OTUsImV4cCI6MTc3MjUzOTI5NX0.g9bzxBFWTdiJlIUSt7d3Xhhm9ZgckZEVAKTTBJ-5L-A

### 建立 Board（需要 JWT）
# @name createBoard
POST {{baseUrl}}/api/boards
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "title": "My First Board",
  "description": "Board created from api.http"
}

### 取得所有 Boards（需要 JWT）
GET {{baseUrl}}/api/boards
Authorization: Bearer {{accessToken}}

### 從建立 Board 回應擷取 boardId
@boardId = a4221021-1cdc-4135-959a-71550254b226

### 更新 Board（需要 JWT）
PUT {{baseUrl}}/api/boards/{{boardId}}
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "title": "My First Board (Updated)",
  "description": "Updated from api.http"
}

### 取得單一 Board（需要 JWT）
GET {{baseUrl}}/api/boards/{{boardId}}
Authorization: Bearer {{accessToken}}

### 刪除 Board（需要 JWT）
DELETE {{baseUrl}}/api/boards/{{boardId}}
Authorization: Bearer {{accessToken}}
