@baseUrl = http://localhost:8080

### 登入
# @name login
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "demo_user",
  "password": "demoPass123"
}

### 從登入回應擷取 token
@accessToken = eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiJjZjZmMTdmNi1hMjNlLTRhY2YtOThjMy1lZTZlNjQ3YzU5ZTEiLCJpYXQiOjE3NzU4MTE5ODUsImV4cCI6MTc3NTgxNTU4NX0.J_KYVlfAbE22bbgb8yaR_76Yqcb3AYIJ0BZaAFyP3C4
@boardId = 54eca13c-8899-49fd-9906-b9bf7f6a6198
@frameId = a047c5f9-82a1-41dd-bbb7-f9582d5dbc1f

### 取得所有我的 Boards（Owner）
GET {{baseUrl}}/api/boards
Authorization: Bearer {{accessToken}}

### 依 boardId 取得 Frames（需要 JWT）
GET {{baseUrl}}/api/frames/{{boardId}}
Authorization: Bearer {{accessToken}}

### 建立 Frame（需要 JWT）
# @name createFrame
POST {{baseUrl}}/api/frames
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "boardId": "{{boardId}}",
  "posX": 100.0,
  "posY": 100.0,
  "width": 400.0,
  "height": 300.0,
  "title": "My Frame"
}

### 更新 Frame（需要 JWT，所有欄位皆可選填）
PUT {{baseUrl}}/api/frames/{{frameId}}
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "posX": 150.0,
  "posY": 150.0,
  "width": 500.0,
  "height": 350.0,
  "title": "Updated Frame Title"
}

### 刪除 Frame（需要 JWT）
DELETE {{baseUrl}}/api/frames/{{frameId}}
Authorization: Bearer {{accessToken}}

### 新增一組 Frame With Event Storming
# @name createFrameWithEventStorming
POST {{baseUrl}}/api/frames/event_storming_template
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "boardId": "{{boardId}}",
  "posX": 100.0,
  "posY": 100.0
}
