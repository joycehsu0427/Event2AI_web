@baseUrl = http://localhost:8080

### 登入
# @name login
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "demo_user",
  "password": "demoPass123"
}

### 從登入回應擷取 token
@accessToken = eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiI3NmY3ZDQzNC0xMmVjLTQzNzUtOTA2NS01ZWZjNDg5NjY3NmMiLCJpYXQiOjE3NzU0MDUyNzAsImV4cCI6MTc3NTQwODg3MH0.hOK6RBagF8pXAed7QImj85_EZW_64OpLm7BdIY-sF7w
@boardId = 223dae65-26aa-4ad9-ac9f-ef9e83bc72a3
@frameId = a047c5f9-82a1-41dd-bbb7-f9582d5dbc1f

### 依 boardId 取得 Frames（需要 JWT）
GET {{baseUrl}}/api/frames/{{boardId}}
Authorization: Bearer {{accessToken}}

### 建立 Frame（需要 JWT）
# @name createFrame
POST {{baseUrl}}/api/frames
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "boardId": "{{boardId}}",
  "posX": 100.0,
  "posY": 100.0,
  "width": 400.0,
  "height": 300.0,
  "title": "My Frame"
}

### 更新 Frame（需要 JWT，所有欄位皆可選填）
PUT {{baseUrl}}/api/frames/{{frameId}}
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "posX": 150.0,
  "posY": 150.0,
  "width": 500.0,
  "height": 350.0,
  "title": "Updated Frame Title"
}

### 刪除 Frame（需要 JWT）
DELETE {{baseUrl}}/api/frames/{{frameId}}
Authorization: Bearer {{accessToken}}
