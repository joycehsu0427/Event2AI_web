@baseUrl = http://localhost:8080

### 登入
# @name login
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "demo_user",
  "password": "demoPass123"
}

### 從登入回應擷取 token
@accessToken = eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiIzMTAwMDAwMC0wMDAwLTAwMDAtMDAwMC0wMDAwMDAwMDAwMDAiLCJpYXQiOjE3NzI1Mzk5MzQsImV4cCI6MTc3MjU0MzUzNH0.0JOEUg4alsF0IuQKxqa5IOPmWC1SSjVlgQdEY95Wous
@boardId = a4221021-1cdc-4135-959a-71550254b226
@frameId = 00000000-0000-0000-0000-000000000000

### 依 boardId 取得 Frames（需要 JWT）
GET {{baseUrl}}/api/frames?boardId={{boardId}}
Authorization: Bearer {{accessToken}}

### 建立 Frame（需要 JWT）
# @name createFrame
POST {{baseUrl}}/api/frames
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "boardId": "{{boardId}}",
  "posX": 100.0,
  "posY": 100.0,
  "width": 400.0,
  "height": 300.0,
  "title": "My Frame"
}

### 更新 Frame（需要 JWT，所有欄位皆可選填）
PUT {{baseUrl}}/api/frames/{{frameId}}
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "posX": 150.0,
  "posY": 150.0,
  "width": 500.0,
  "height": 350.0,
  "title": "Updated Frame Title"
}

### 刪除 Frame（需要 JWT）
DELETE {{baseUrl}}/api/frames/{{frameId}}
Authorization: Bearer {{accessToken}}
